{
  "name": "ztna-web3-access-registry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "node": "hardhat node --hostname 127.0.0.1",
    "deploy": "node scripts/deploy.js",
    "allow": "node scripts/set-access.js allow",
    "revoke": "node scripts/set-access.js revoke",
    "status": "node scripts/status.js",
    "sync": "node scripts/sync-ziti.js --once",
    "sync:watch": "node scripts/sync-ziti.js --watch 1000"
  },
  "devDependencies": {
    "ethers": "6.14.4",
    "hardhat": "2.26.3",
    "solc": "0.8.30"
  }
}
